# Pusher設定（https://pusher.com で無料アカウントを作成して取得）
NEXT_PUBLIC_PUSHER_APP_KEY=your_pusher_app_key_here
NEXT_PUBLIC_PUSHER_CLUSTER=ap3
PUSHER_APP_ID=your_pusher_app_id_here
PUSHER_SECRET=your_pusher_secret_here

# 使用方法:
# 1. このファイルを .env.local にコピー
#    cp .env.local.example .env.local
#
# 2. Pusher にアクセスして無料アカウントを作成
#    https://pusher.com
#
# 3. 新しいアプリを作成し、認証情報を取得
#
# 4. 上記の値を実際の認証情報に置き換える
#
# 注意: .env.local はGitにコミットしないでください